# Código completo

```python
import pandas as pd
import matplotlib.pyplot as plt
from sklearn.cluster import KMeans

# -----------------------------
# Dataset
# -----------------------------

clientes = pd.DataFrame({
    "Edad":[20,22,23,24,45,46,47,48,33,34,35,36],
    "Gasto":[180,200,170,210,950,980,920,1000,520,540,500,560]
})

# -----------------------------
# Datos originales
# -----------------------------

plt.figure(figsize=(7,5))

plt.scatter(
    clientes["Edad"],
    clientes["Gasto"],
    s=80
)

plt.xlabel("Edad")
plt.ylabel("Gasto mensual")
plt.title("Clientes")
plt.grid()

plt.show()

# -----------------------------
# K-Means
# -----------------------------

modelo = KMeans(
    n_clusters=3,
    random_state=42
)

clientes["Cluster"] = modelo.fit_predict(
    clientes[["Edad","Gasto"]]
)

# -----------------------------
# Resultado
# -----------------------------

plt.figure(figsize=(7,5))

plt.scatter(
    clientes["Edad"],
    clientes["Gasto"],
    c=clientes["Cluster"],
    s=80
)

plt.scatter(
    modelo.cluster_centers_[:,0],
    modelo.cluster_centers_[:,1],
    marker="X",
    s=250
)

plt.xlabel("Edad")
plt.ylabel("Gasto mensual")
plt.title("Clusters encontrados por K-Means")
plt.grid()

plt.show()

# -----------------------------
# Centroides
# -----------------------------

centroides = pd.DataFrame(
    modelo.cluster_centers_,
    columns=["Edad","Gasto"]
)

print(centroides)
```
